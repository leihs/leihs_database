#!/usr/bin/env bash

set -euo pipefail
# set -x

PROJECT_DIR="$(cd -- "$(dirname "${BASH_SOURCE}")" ; cd .. > /dev/null 2>&1 && pwd -P)"
cd $PROJECT_DIR

RAILS_ENV=${RAILS_ENV:-development}
echo "RAILS_ENV=$RAILS_ENV"
source bin/db-set-env

psql -d $PGDATABASE <<SQL 
  UPDATE users 
  SET password_sign_in_enabled = TRUE
  WHERE account_enabled;
SQL

RAILS_ENV=$RAILS_ENV bundle exec rails runner - <<RB
  pw_hash = ActiveRecord::Base.connection.execute(<<~SQL)
    SELECT crypt('password', gen_salt('bf')) AS pw_hash
  SQL
    .first['pw_hash']

  class User < ActiveRecord::Base; end
  class AuthenticationSystemsUser < ActiveRecord::Base
    self.table_name = "authentication_systems_users"
  end

  rows = User.where(account_enabled: true).pluck(:id).map do |user_id|
    {
      user_id: user_id,
      authentication_system_id: "password",
      data: pw_hash
    }
  end

  unless rows.empty?
    AuthenticationSystemsUser.upsert_all(
      rows,
      unique_by: %i[user_id authentication_system_id]
    )
  end
RB

echo "Password sign-in was enabled for all users with enabled account."
echo "Password for all users with enabled account has been set to 'password'."
