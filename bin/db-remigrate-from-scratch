#!/usr/bin/env bash
set -euo pipefail
# set -x

PROJECT_DIR="$(cd -- "$(dirname "${BASH_SOURCE}")" ; cd .. > /dev/null 2>&1 && pwd -P)"
cd $PROJECT_DIR
./bin/env/ruby-setup

RAILS_ENV=${RAILS_ENV:-test}
source bin/db-set-env

terminate_connections

dropdb --if-exists $PGDATABASE
createdb $PGDATABASE

bundle exec rake db:migrate "$@" 


### add seeds to dump

exit 0

pg_dump --data-only --no-privileges --no-owner --inserts --column-inserts \
  -T ar_internal_metadata -T schema_migrations \
  -T audited_changes -T audited_requests -T audited_responses -T audits \
  >> db/structure.sql

# vi: ft=sh
