#!/usr/bin/env bash
set -euo pipefail
# set -x

PROJECT_DIR="$(cd -- "$(dirname "${BASH_SOURCE}")" ; cd .. > /dev/null 2>&1 && pwd -P)"
cd $PROJECT_DIR
./bin/env/ruby-setup

RAILS_ENV=${RAILS_ENV:-test}
source bin/db-set-env

terminate_connections

dropdb --if-exists $PGDATABASE
createdb $PGDATABASE

psql -d $PGDATABASE \
  --single-transaction --quiet --echo-errors \
  --file db/structure_and_seeds_001.sql

bundle exec rake db:migrate

pg_dump --no-owner --no-privileges \
  --inserts --column-inserts \
  --file db/structure_and_seeds.sql \
  $PGDATABASE


cat <<-SQL > db/seeds.sql
-- this file is automatically generated for testing purposes
-- it represents the current seed data but it is not the source
--
-- for technical reasons the source is structure_and_seeds_001.sql 
-- and all migrations


SQL


pg_dump --no-owner --no-privileges \
  --data-only -T schema_migrations -T ar_internal_metadata \
  --inserts --column-inserts \
  $PGDATABASE >> db/seeds.sql

